# Local dev uses a SQLite file; for Turso use libsql://... + auth token
DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=

# TMDB "API Read Access Token" (the long Bearer token, not the short api key)
TMDB_API_TOKEN=

# Signs session cookies — generate with: openssl rand -hex 32
AUTH_SECRET=

# Region for streaming-provider availability (TMDB watch region code, e.g. CA, US, GB)
WATCH_REGION=CA
